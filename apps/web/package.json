{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run && vitest run -c vitest.workers.config.ts",
    "test:watch": "vitest",
    "test:db": "vitest run -c vitest.workers.config.ts",
    "test:e2e": "playwright test",
    "deploy": "vite build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply lil-media --local",
    "db:migrate": "wrangler d1 migrations apply lil-media --remote",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^1.3.3",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-router": "^1.170.8",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.14",
    "@tanstack/router-plugin": "^1.168.11",
    "@workspace/ui": "workspace:*",
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@clerk/backend": "^3.5.0",
    "@clerk/testing": "^2.0.35",
    "@cloudflare/vite-plugin": "^1.40.0",
    "@cloudflare/vitest-pool-workers": "^0.16.13",
    "@playwright/test": "^1.60.0",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "happy-dom": "^20.10.2",
    "typescript": "^6",
    "vite": "^8",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
}
